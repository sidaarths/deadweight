{
  "name": "deadweight",
  "version": "0.1.0",
  "description": "npm audit finds CVEs. deadweight finds everything else.",
  "type": "module",
  "bin": {
    "deadweight": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "dependencies",
    "security",
    "npm",
    "license",
    "maintenance"
  ],
  "license": "MIT",
  "dependencies": {
    "@keyv/sqlite": "^4.0.8",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "keyv": "^5.6.0",
    "p-limit": "^7.3.0",
    "smol-toml": "^1.6.1",
    "spdx-correct": "^3.2.0",
    "spdx-satisfies": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
