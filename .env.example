# Required for GitHub-based health signals (repo last commit, archived status, open issues)
# Get a free token at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Optional: libraries.io for SourceRank + dependent counts
# Get a free key at https://libraries.io/api
LIBRARIES_IO_API_KEY=

# Cache configuration
DEADWEIGHT_CACHE_DIR=~/.deadweight/cache
DEADWEIGHT_CACHE_TTL=3600

# Rate limiting (requests per second per registry)
DEADWEIGHT_RATE_LIMIT=10
